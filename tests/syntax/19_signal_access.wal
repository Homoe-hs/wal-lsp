;; ============================================================
;; 19_signal_access.wal — Test signal access functions
;;   (get, slice, reval, @ macro)
;; ============================================================

;; get — read signal value
(get tb.clk)
(get "tb.reset")

;; slice — extract bit range
(slice tb.data 7 0)
(slice tb.addr 31 24)
(slice INDEX 10 0)

;; reval — relative evaluation
(reval tb.clk 1)
(reval tb.clk -1)
(reval INDEX 5)
(reval INDEX -3)

;; @ — reval shorthand macro
tb.clk@1
tb.clk@-1
INDEX@5
INDEX@3

;; @ with expressions (list offset)
INDEX@(+ 2 2)
INDEX@(- 2)
tb.data@(get tb.offset)

;; Combined pattern: signal access in conditionals
(when (> (reval tb.clk -1) 0)
  (print "Previous clock was high"))

;; get with expression result
(let ([sig-name "tb.clk"])
  (get sig-name))

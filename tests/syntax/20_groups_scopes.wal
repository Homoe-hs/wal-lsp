;; ============================================================
;; 20_groups_scopes.wal — Test groups and scopes functions
;;   (groups, in-groups, resolve-group, #, in-scope, in-scopes, all-scopes)
;; ============================================================

;; groups — find groups based on signal suffixes
(groups '("valid" "ready"))
(groups '("clk" "reset" "data"))

;; in-groups — evaluate in each group
;; (in-groups (groups '("valid" "ready"))
;;   (print CG ":")
;;   (whenever (&& #valid #ready)
;;     (print INDEX)))

;; resolve-group — resolve group-prefixed signal
;; (resolve-group #valid)
;; Equivalent to: evaluate signal CG + "valid"

;; # — resolve-group shorthand
#valid
#ready
#data

;; CG — current group (special variable)
CG

;; in-scope — evaluate in specified scope
;; (in-scope my-scope
;;   (print "in scope")
;;   (print ~signal))

;; in-scopes — evaluate in each scope
;; (in-scopes (all-scopes)
;;   (print CS ":")
;;   (print ~clk))

;; all-scopes — get all available scopes
;; (all-scopes)

;; Scoped symbol (~)
~clk
~reset
~data

;; Grouped + Scoped mixed
(when (&& #valid ~enable)
  (print "Handshake detected at INDEX:" INDEX))


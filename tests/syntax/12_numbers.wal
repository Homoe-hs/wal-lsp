;; Decimal integers
0
1
42
+100
-50
65535

;; Binary integers (0b prefix)
0b1
0b0
0b1010
0b11111111
0b0101

;; Hexadecimal integers (0x prefix)
0xFF
0x0
0x1A
0xabcd
0xBEEF
0xDEAD
0xdeadbeef
0xFFFF

;; Floating point
0.0
1.5
+3.14
-2.718
123.456
0.001

;; Arithmetic with mixed number types
(+ 1 0xFF)
(* 2 0b1010)
(- 0x10 1)
(/ 10.0 3)

;; Comparison with hex/bin
(= 0xFF 255)
(= 0b10 2)
(> 0xFF 0x0F)

;; Negative numbers in various formats
(- -5)
(+ -10 20)

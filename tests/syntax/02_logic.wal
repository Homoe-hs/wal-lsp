;; ============================================================
;; 02_logic.wal — Test all logical and comparison operators
;; ============================================================

;; Logical NOT
(! 0)
(! 1)
(! #f)
(! #t)
(! true)
(! false)

;; Logical AND (variadic)
(&& 1 1)
(&& #t #t)
(&& true true true)
(&& 1 1 0)
(&& #t #t #f)

;; Logical OR (variadic)
(|| 0 0)
(|| 0 1)
(|| #f #t)
(|| false true false)

;; Equality (variadic)
(= 5 5)
(= 1 2)
(= "hello" "hello")
(= #t #t)
(= '(1 2) '(1 2))
(= 1 1 1)

;; Inequality (variadic)
(!= 1 2)
(!= 5 5)
(!= "a" "b")

;; Comparison (binary)
(> 5 3)
(> 1 10)
(< 5 3)
(< 1 10)
(>= 5 5)
(>= 5 3)
(<= 5 5)
(<= 5 3)

;; Combined logic
(&& (> 10 5) (< 3 10))
(|| (!= 1 2) (= 3 3))
(! (&& 1 0))
(&& (>= 5 5) (<= 3 5) (!= 1 2))

;; Boolean literals (both forms)
true
false
#t
#f

;; --- GARBLED ERRORS BELOW ---
;; Error 5: not expects 1 arg, got 2
(not #t #f)

;; Error 6: if in logic file (unknown context)
(if #t 1)

;; Error 7: garbage operator
(!== 1 2)

;; Error 8: unclosed string
(print "hello world)

;; Error 9: misparenthesized logic
(&& #t #f
  (|| 1 0)))

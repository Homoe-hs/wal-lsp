;; ============================================================
;; 01_arithmetic.wal — Test all arithmetic operators
;; ============================================================

;; + (variadic)
(+ 1 2 3 4)
(+)
(+ -1 5)

;; - (variadic)
(- 10 3)
(- 100 20 5)
(- 42)

;; * (variadic)
(* 2 3 4)
(*)
(* 0.5 10)

;; / (binary only per docs)
(/ 10 3)
(/ 100 5)
(/ -20 4)
(/ 1 3)

;; ** (power - binary)
(** 2 8)
(** 10 0)
(** 3 4)

;; Nested arithmetic
(+ (* 2 3) (/ 10 2) (- 5 1))
(* (+ 1 2) (/ 9 3))
(** (+ 1 2) (- 5 1))

;; Floating point
(+ 1.5 2.5)
(* 3.14 2)
(/ 10.0 3.0)
(** 2.5 2)

;; --- GARBLED ERRORS BELOW ---
;; Error 1: unclosed parenthesis
(+ 1 (* 2 3

;; Error 2: unknown function name (garbled)
(florbnoz 42 "test")

;; Error 3: extra closing paren
(+ 5 10))

;; Error 4: junk tokens
@#$%^&*()

;; ============================================================
;; 15_comments.wal — Test comment syntax and edge cases
;; ============================================================

;; Single line comment

;; Comment before code
(define x 10)

(define y 20) ;; Inline comment after code

;; Multiple comment lines
;; Line 1
;; Line 2
;; Line 3

(do
  ;; Comment inside do block
  (define z 30)
  ;; Another comment
  (+ x y))

;; Comment with special characters: @ # $ % ^ & * ( ) [ ] { } < > / \ | , .

;; Comment-only file section (no code)

;; Comment with WAL syntax inside
;; (define test "this is commented out")
;; (print "this won't run")

(define result (+ x y)) ;; End-of-line comment

;; Final comment

;; 
;; Empty-ish comments
;;

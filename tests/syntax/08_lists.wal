;; ============================================================
;; 08_lists.wal — Test all list functions
;; ============================================================

;; list — construction
(list 1 2 3)
(list "a" "b" "c")
(list (+ 1 2) (* 3 4))
(list)
(list #t #f true false)

;; Quoted list literal (sugar)
'(1 2 3 4 5)

;; first
(first (list 1 2 3))
(first '(10 20 30))

;; second
(second (list 1 2 3))
(second '(a b c))

;; last
(last (list 1 2 3 4 5))
(last '(x y z))

;; rest
(rest (list 1 2 3))
(rest '(a b c d))

;; in
(in 2 '(1 2 3))
(in "a" (list "a" "b" "c"))
(in 99 '(1 2 3))

;; map
(map (fn [x] (* x 2)) '(1 2 3 4))
(map (fn [s] (print s)) (list "hello" "world"))

;; fold
(fold + 0 '(1 2 3 4 5))
(fold * 1 '(1 2 3 4 5))

;; zip
(zip '(1 2 3) '(a b c))

;; max / min
(max '(1 5 3 9 2))
(min '(1 5 3 9 2))
(max '(1))
(min '(42))

;; sum
(sum '(1 2 3 4 5))
(sum '(-1 1))

;; average
(average '(1 2 3 4 5))
(average '(10 20 30))

;; length
(length '(1 2 3))
(length (list))
(length (list "a" "b" "c"))

;; Chained list operations
(first (rest '(1 2 3 4)))

;; length of map result
(length (map (fn [x] (+ x 1)) '(1 2 3)))

;; fold with lambda
(fold (fn [acc x] (+ acc x)) 0 '(10 20 30))

;; --- GARBLED ERRORS BELOW ---
;; Error 20: first with wrong arity (0 args)
(first)

;; Error 21: unknown list function
(sorted '(5 3 1 4 2))

;; Error 22: malformed quoted list (missing closing paren)
'(1 2 3

;; Error 23: list with garbage separator
(list 1, 2, 3)

;; Error 24: length with wrong arity (2 args)
(length '(1 2) '(3 4))

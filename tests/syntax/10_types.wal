;; ============================================================
;; 10_types.wal — Test type predicates and conversions
;; ============================================================

;; atom? — checks for atomic values
(atom? 42)
(atom? "hello")
(atom? #t)
(atom? 'symbol)
(atom? '(1 2 3))
(atom? (list 1 2))
(atom? (array))

;; symbol? — checks for symbol type
(symbol? 'hello)
(symbol? "not-a-symbol")
(symbol? 42)
(symbol? (list 1 2))

;; string? — checks for string type
(string? "hello")
(string? 'symbol)
(string? 42)
(string? #t)

;; int? — checks for integer type
(int? 42)
(int? -1)
(int? 3.14)
(int? "42")
(int? #t)

;; list? — checks for list type
(list? (list 1 2 3))
(list? '(1 2 3))
(list? 42)
(list? "hello")
(list? (array))

;; convert/bin — integer to binary string
(convert/bin 5 8)
(convert/bin 255 8)
(convert/bin 0 4)
(convert/bin 42 16)

;; Chained type checks
(if (int? 42)
    (print "Is integer")
    (print "Is NOT integer"))

(if (list? '(1 2))
    (print "Is list")
    (print "Is NOT list"))

(if (atom? "test")
    (print "Is atom")
    (print "Is NOT atom"))

;; All types tested together
(do
  (define x 42)
  (define s "hello")
  (define l (list 1 2 3))
  (list (int? x) (string? s) (list? l)))

;; nil / null — edge cases
(atom? nil)
(list? nil)
